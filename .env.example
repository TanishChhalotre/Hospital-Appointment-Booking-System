# Copy to server/.env for local development. Never commit the real .env file.
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/gurjar-hospital
JWT_SECRET=replace_with_at_least_32_random_characters
CLIENT_URL=http://localhost:5173
PORT=5000
# Enables demo departments/doctors/users. Set false in a real production system.
SEED_DATABASE=true
